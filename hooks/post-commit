#!/usr/bin/env bash
# Auto-refresh digital-brain extracted layer when source files change.
# Symlinked into .git/hooks/post-commit by hooks/install.sh.
#
# Locates digital-brain via this script's own path (works after extraction
# to standalone repo + symlinking back into host repos).
#
# Skips:
#  - if .digital-brain-config.yaml absent in host repo
#  - if commit didn't touch source_paths
#  - if helpers venv missing

set -euo pipefail

# Host repo (where the commit happened)
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Resolve this script's real location (follow symlinks) → digital-brain dir
SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$0")"
DIGITAL_BRAIN_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
HELPERS_PY="$DIGITAL_BRAIN_DIR/helpers/.venv/bin/python"

[ -f .digital-brain-config.yaml ] || exit 0
[ -x "$HELPERS_PY" ] || exit 0

# Resolve source_paths from config (relative form, host-repo)
SRC_REL=$("$HELPERS_PY" -c "
import sys; sys.path.insert(0, '$DIGITAL_BRAIN_DIR/helpers/src')
from pathlib import Path
from digital_brain_helpers.config import load_config
print(' '.join(load_config(Path('.').resolve()).source_paths))
" 2>/dev/null) || exit 0

# Did this commit touch any source path?
CHANGED=$(git diff --name-only HEAD~1 HEAD 2>/dev/null || true)
TOUCHED=0
for src in $SRC_REL; do
    if echo "$CHANGED" | grep -q "^${src%/}"; then
        TOUCHED=1
        break
    fi
done
[ "$TOUCHED" = "1" ] || exit 0

# Run auto-refresh in background — do not block git
(
    "$HELPERS_PY" "$DIGITAL_BRAIN_DIR/hooks/auto_refresh.py" 2>&1 | \
        sed 's/^/[digital-brain post-commit] /' >&2
) &
disown
exit 0
